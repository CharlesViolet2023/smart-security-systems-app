# SmartSec Configuration (copy this to .env and fill in your values)
# -------------------------------------------------------------------

# Path to Firebase service account JSON key file
# Download from: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# FCM topic that mobile app subscribes to for notifications
FCM_TOPIC=office_security

# SQLite database file path
DATABASE_PATH=./security.db

# Flask API server port
API_PORT=5000
